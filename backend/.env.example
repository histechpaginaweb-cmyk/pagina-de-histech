# ─────────────────────────────────────────────────────────────
# Backend HISTECH — variables de entorno (copiar a .env en local;
# en Render se ponen en "Environment"). NUNCA subir el .env real.
# ─────────────────────────────────────────────────────────────

# Puerto (Render lo asigna solo; en local usa 4000)
PORT=4000

# Origen del frontend permitido para CORS (tu dominio de Vercel)
# Ej: https://histech.vercel.app  (en local: http://localhost:3000)
FRONTEND_ORIGIN=http://localhost:3000

# ── Cloudflare R2 (almacena las tarjetas en products.json + las imágenes) ──
# Dashboard de Cloudflare → R2. Crea un bucket y un API Token (S3 credentials).
#   R2_ACCOUNT_ID       → ID de tu cuenta de Cloudflare (R2 → "Account details")
#   R2_ACCESS_KEY_ID    → del API Token de R2
#   R2_SECRET_ACCESS_KEY→ del API Token de R2 (solo se ve una vez al crearlo)
#   R2_BUCKET           → nombre del bucket que creaste (ej. histech)
#   R2_PUBLIC_URL       → URL pública del bucket para que el sitio vea las imágenes.
#                         Habilita "Public access" del bucket (dominio r2.dev) o usa
#                         un dominio propio. Ej: https://pub-xxxxxxxx.r2.dev
R2_ACCOUNT_ID=tu_account_id
R2_ACCESS_KEY_ID=tu_access_key_id
R2_SECRET_ACCESS_KEY=tu_secret_access_key
R2_BUCKET=histech
R2_PUBLIC_URL=https://pub-xxxxxxxx.r2.dev

# ── Admin (login del panel) ──
# Usuario y contraseña para entrar al panel /admin. CÁMBIALOS.
ADMIN_USER=admin
ADMIN_PASSWORD=cambia-esta-clave

# Secreto para firmar la sesión (pon una cadena larga y aleatoria)
JWT_SECRET=pon-aqui-una-cadena-larga-y-aleatoria
