# ── HISTECH · Variables de entorno ──────────────────────────────
# URL pública del sitio (usada para SEO, sitemap, canonical, OG)
NEXT_PUBLIC_SITE_URL=https://histech.com.co

# Resend — envío del formulario de contacto (https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# Correo destino y remitente del formulario
CONTACT_TO_EMAIL=consultor@histech.com.co
CONTACT_FROM_EMAIL=Histech Web <web@histech.com.co>

# Backend de productos (Render). El carrusel lee de aquí; si se deja vacío,
# usa los 6 productos seed locales. Ej: https://histech-backend.onrender.com
BACKEND_URL=
